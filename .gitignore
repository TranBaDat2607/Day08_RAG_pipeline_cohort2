# ---- Data artifacts (downloaded/generated by the pipeline) ----
# Task 1/2 download corpora; Task 3 produces standardized markdown.
# These are regenerable and often large/binary — keep them out of git.
data/landing/legal/*
data/landing/news/*
data/standardized/legal/*
data/standardized/news/*
crawling_page.html

# Keep the directory structure in git
!data/landing/legal/.gitkeep
!data/landing/news/.gitkeep
!data/standardized/legal/.gitkeep
!data/standardized/news/.gitkeep

